DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
DJANGO_TIME_ZONE=Europe/Paris
DJANGO_STATIC_ROOT=/var/app/static
DJANGO_MEDIA_ROOT=/var/app/media
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
DJANGO_SECURE_SSL_REDIRECT=False
POSTGRES_DB=prenium_dtf
POSTGRES_USER=prenium_dtf
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
NGINX_PORT=8080
ORDER_UPLOAD_MAX_BYTES=20971520
ORDER_UPLOAD_ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg,image/svg+xml,image/tiff,application/postscript,image/vnd.adobe.photoshop,application/x-photoshop
# Tarification DTF (m²) : DPI inspection, laize film (cm), mode aire (laize_fit = tient compte de la laize)
DTF_PRINT_DPI=300
DTF_LAIZE_CM=55
DTF_METERAGE_AREA_MODE=laize_fit
GOOGLE_DRIVE_SYNC_ENABLED=False
GOOGLE_DRIVE_SHARED_DRIVE_ID=
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_TIMEOUT_SECONDS=30
SENDCLOUD_PUBLIC_KEY=
SENDCLOUD_SECRET_KEY=
